# Postgres connection string — get this from your Neon / Supabase / Railway dashboard
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Port the API listens on (defaults to 3000 if unset)
PORT=3000

# Allowed CORS origin for your frontend (set to your Vite dev server or deployed URL)
# Leave unset to allow all origins (fine for local dev, lock down for production)
FRONTEND_ORIGIN=http://localhost:5173
